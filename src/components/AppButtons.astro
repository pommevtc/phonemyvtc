---
// src/components/AppButtons.astro
const appName = 'PhoneMyVTC';
---

<div class="app-buttons">
  <p class="app-title">📱 Téléchargez l'application {appName}</p>

  <div class="app-links">
    <a
      href="https://apps.apple.com/fr/app/phoneme-vtc/id6447442748"
      target="_blank"
      rel="noopener noreferrer"
      class="app-btn apple"
      aria-label={`Télécharger l'application ${appName} sur l'App Store`}
    >
      <svg
        class="app-icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
      </svg>

      <span class="app-text">
        <small>Télécharger sur</small>
        <strong>App Store</strong>
      </span>
    </a>

    <a
      href="https://play.google.com/store/apps/details?id=fr.phonemevtc.user&pcampaignid=web_share"
      target="_blank"
      rel="noopener noreferrer"
      class="app-btn android"
      aria-label={`Télécharger l'application ${appName} sur Google Play`}
    >
      <svg
        class="app-icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path d="M3.18 23.76c.3.17.64.22.99.14l12.47-7.18-2.61-2.61-10.85 9.65zM.44 1.6C.17 1.9 0 2.33 0 2.88v18.24c0 .55.17.98.44 1.28l.07.07 10.22-10.22v-.24L.51 1.53l-.07.07zM20.13 10.4l-2.77-1.6-2.93 2.93 2.93 2.93 2.79-1.61c.8-.46.8-1.2-.02-1.65zM3.18.24L15.65 7.4l-2.61 2.61L2.19.36c.35-.08.7-.03.99.12-.01 0 0-.24 0-.24z" />
      </svg>

      <span class="app-text">
        <small>Disponible sur</small>
        <strong>Google Play</strong>
      </span>
    </a>
  </div>
</div>

<style>
  .app-buttons {
    text-align: center;
    margin: 2rem 0;
    padding: 2rem;
    background: #f8faff;
    border-radius: 16px;
    border: 1px solid #e0e8f0;
  }

  .app-title {
    font-weight: 600;
    color: #1a1a2e;
    margin-bottom: 1.2rem;
    font-size: 1.1rem;
  }

  .app-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .app-btn {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    width: 220px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .app-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .apple {
    background: #1a1a2e;
    color: white;
    border: 2px solid #1a1a2e;
  }

  .android {
    background: #f5f5f5;
    color: #1a1a2e;
    border: 2px solid #cccccc;
  }

  .app-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .app-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .app-text small {
    font-size: 0.7rem;
    opacity: 0.8;
    font-weight: 400;
  }

  .app-text strong {
    font-size: 1rem;
  }

  @media (max-width: 640px) {
    .app-buttons {
      padding: 1.5rem 1rem;
    }

    .app-btn {
      width: 100%;
      max-width: 280px;
      justify-content: flex-start;
    }
  }
</style>